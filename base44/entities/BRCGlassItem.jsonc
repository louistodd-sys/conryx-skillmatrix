{
  "name": "BRCGlassItem",
  "type": "object",
  "properties": {
    "organisation_id": {
      "type": "string",
      "title": "Organisation ID"
    },
    "item_description": {
      "type": "string",
      "title": "Item Description"
    },
    "item_type": {
      "type": "string",
      "title": "Item Type",
      "enum": [
        "glass",
        "hard_plastic",
        "brittle_metal",
        "ceramic",
        "other"
      ],
      "default": "glass"
    },
    "location": {
      "type": "string",
      "title": "Location / Area"
    },
    "risk_level": {
      "type": "string",
      "title": "Risk Level",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "medium"
    },
    "last_checked_date": {
      "type": "string",
      "title": "Last Checked Date (ISO date)"
    },
    "next_check_date": {
      "type": "string",
      "title": "Next Check Date (ISO date)"
    },
    "check_frequency_months": {
      "type": "number",
      "title": "Check Frequency (months)",
      "default": 1
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "ok",
        "damaged",
        "replaced",
        "removed"
      ],
      "default": "ok"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    },
    "checked_by": {
      "type": "string",
      "title": "Checked By"
    }
  },
  "required": [
    "organisation_id",
    "item_description",
    "item_type",
    "location",
    "risk_level",
    "status"
  ]
}