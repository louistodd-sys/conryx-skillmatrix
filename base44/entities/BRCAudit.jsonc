{
  "name": "BRCAudit",
  "type": "object",
  "properties": {
    "organisation_id": {
      "type": "string",
      "title": "Organisation ID"
    },
    "title": {
      "type": "string",
      "title": "Audit Title"
    },
    "audit_type": {
      "type": "string",
      "title": "Audit Type",
      "enum": [
        "internal",
        "third_party",
        "regulatory",
        "supplier"
      ],
      "default": "internal"
    },
    "scheduled_date": {
      "type": "string",
      "title": "Scheduled Date (ISO date)"
    },
    "completed_date": {
      "type": "string",
      "title": "Completed Date (ISO date)"
    },
    "lead_auditor_id": {
      "type": "string",
      "title": "Lead Auditor User ID"
    },
    "lead_auditor_name": {
      "type": "string",
      "title": "Lead Auditor Name"
    },
    "scope": {
      "type": "string",
      "title": "Scope / Areas Covered"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "planned",
        "in_progress",
        "completed",
        "overdue"
      ],
      "default": "planned"
    },
    "overall_rating": {
      "type": "string",
      "title": "Overall Rating",
      "enum": [
        "satisfactory",
        "minor_issues",
        "major_issues",
        "critical"
      ]
    },
    "summary": {
      "type": "string",
      "title": "Summary / Findings"
    },
    "clause_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Clause References"
    },
    "nc_count": {
      "type": "number",
      "title": "Non-Conformance Count",
      "default": 0
    },
    "next_audit_date": {
      "type": "string",
      "title": "Next Audit Date (ISO date)"
    }
  },
  "required": [
    "organisation_id",
    "title",
    "audit_type",
    "scheduled_date",
    "status"
  ]
}