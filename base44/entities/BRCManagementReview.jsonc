{
  "name": "BRCManagementReview",
  "type": "object",
  "properties": {
    "organisation_id": {
      "type": "string",
      "title": "Organisation ID"
    },
    "meeting_date": {
      "type": "string",
      "title": "Meeting Date (ISO date)"
    },
    "chair_name": {
      "type": "string",
      "title": "Chair / Facilitator"
    },
    "attendees": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Attendees"
    },
    "agenda_items": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Agenda Items"
    },
    "kpi_summary": {
      "type": "string",
      "title": "KPI Summary"
    },
    "audit_summary": {
      "type": "string",
      "title": "Audit Results Summary"
    },
    "nc_summary": {
      "type": "string",
      "title": "NC / CAPA Summary"
    },
    "customer_feedback": {
      "type": "string",
      "title": "Customer Feedback Summary"
    },
    "actions": {
      "type": "string",
      "title": "Actions / Decisions"
    },
    "next_meeting_date": {
      "type": "string",
      "title": "Next Meeting Date (ISO date)"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "scheduled",
        "completed",
        "minutes_approved"
      ],
      "default": "scheduled"
    },
    "minutes_url": {
      "type": "string",
      "title": "Minutes File URL"
    }
  },
  "required": [
    "organisation_id",
    "meeting_date",
    "chair_name",
    "status"
  ]
}