{
  "name": "BRCCAPA",
  "type": "object",
  "properties": {
    "organisation_id": {
      "type": "string",
      "title": "Organisation ID"
    },
    "ref_number": {
      "type": "string",
      "title": "Reference Number"
    },
    "nc_id": {
      "type": "string",
      "title": "Non-Conformance ID"
    },
    "nc_ref": {
      "type": "string",
      "title": "NC Reference"
    },
    "title": {
      "type": "string",
      "title": "CAPA Title"
    },
    "corrective_action": {
      "type": "string",
      "title": "Corrective Action"
    },
    "preventive_action": {
      "type": "string",
      "title": "Preventive Action"
    },
    "responsible_user_id": {
      "type": "string",
      "title": "Responsible User ID"
    },
    "responsible_name": {
      "type": "string",
      "title": "Responsible Name"
    },
    "raised_date": {
      "type": "string",
      "title": "Raised Date (ISO date)"
    },
    "due_date": {
      "type": "string",
      "title": "Due Date (ISO date)"
    },
    "completed_date": {
      "type": "string",
      "title": "Completed Date (ISO date)"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "open",
        "in_progress",
        "completed",
        "verified",
        "overdue"
      ],
      "default": "open"
    },
    "effectiveness_review": {
      "type": "string",
      "title": "Effectiveness Review Notes"
    },
    "clause_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Clause References"
    }
  },
  "required": [
    "organisation_id",
    "title",
    "status",
    "raised_date"
  ]
}